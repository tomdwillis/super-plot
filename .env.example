# Database
DATABASE_URL=postgresql://superplot:superplot@localhost:5432/superplot

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STANDARD=price_...
STRIPE_PRICE_PREMIUM=price_...

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Auth (magic link sessions)
# Generate with: openssl rand -base64 32
AUTH_SESSION_SECRET=change-me-generate-a-secure-random-string

# Email (Resend — https://resend.com)
# Leave blank in development to log magic links to console instead
RESEND_API_KEY=re_...
EMAIL_FROM=Super Plot <noreply@superplot.com>

# Pipeline worker auth
# Protects POST /api/pipeline/process-jobs
# Generate with: openssl rand -base64 32
PIPELINE_SECRET=change-me-generate-a-secure-random-string
CRON_SECRET=change-me-generate-a-secure-random-string

# Admin email allowlist (comma-separated)
# Required for /admin/* and /api/admin/*
ADMIN_EMAILS=admin@example.com

# Analytics dashboard
# Protects /admin/analytics and GET /api/admin/analytics
# Leave blank in development to disable auth on that endpoint
# Generate with: openssl rand -base64 32
ANALYTICS_SECRET=
